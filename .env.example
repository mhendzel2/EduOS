# Copy this file to `.env` in the repository root for local EduOS development.
# Shared defaults live here. Use `backend/.env` only for backend-specific overrides.
# Relative backend paths below resolve from `backend/`.

# Frontend / local URLs
NEXT_PUBLIC_API_URL=http://127.0.0.1:8090
REDIS_URL=redis://127.0.0.1:6379/0
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Required: configure at least one LLM provider
# Default cloud order matches ResearchAgent-style routing:
# openrouter -> google/gemini -> ollama -> openai -> anthropic
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
YOUTUBE_API_KEY=
GOOGLE_OAUTH_CLIENT_FILE=./google-oauth-client.json

# Provider/model routing
PROVIDER_PRIORITY=openrouter,google,ollama,openai,anthropic
DEFAULT_MODEL=gemini-2.5-flash
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
LOCAL_AUTOFILL_MODEL=ollama/llama3
LOCAL_WORKFLOW_MODEL=ollama/llama3
LOCAL_VISION_MODEL=ollama/llava
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
MULTIMODAL_VIDEO_FRAME_COUNT=4
MULTIMODAL_VIDEO_FRAME_WINDOW_SECONDS=60
MULTIMODAL_AUDIO_TRANSCRIPTION_ENABLED=true
MULTIMODAL_AUDIO_TRANSCRIPTION_MAX_SECONDS=90

# Local models (optional)
OLLAMA_BOOTSTRAP_SCRIPT=./scripts/bootstrap_ollama.sh

# Local content sources
CELLNUCLEUS_SITE_PATH=C:/Users/mjhen/Github/cellnucleus.com
AGENT0_WORKDIR=C:/Users/mjhen/Github/Agent0/agent-zero/usr/workdir

# Telegram control (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_PROJECT_ID=
TELEGRAM_DEFAULT_SCOPE=general

# Embeddings
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Database
DATABASE_URL=sqlite:///./edu_os.db

# Vector DB
VECTOR_DB_PATH=./vector_store

# Storage
UPLOAD_DIR=./uploads

# Security
SECRET_KEY=change-me-in-production
SECURITY_MODE=MODE_A

# EduOS
GATE_REVISION_MAX_RETRIES=3
BIBLE_AUTO_UPDATE=true
YOUTUBE_COMMENTS_DEFAULT_MAX_RESULTS=25
